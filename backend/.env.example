# ============================================================
# .env.local — Variables de entorno (NUNCA subir a GitHub)
# ============================================================
# Copia este archivo como ".env.local" en la raíz del proyecto Next.js
# y llena cada valor desde tu cuenta de Supabase

# ---- SUPABASE ----
# Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo para Edge Functions y backend (NO usar en frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- MERCADO PAGO ----
# mercadopago.com > Credenciales
# Usar TEST credentials para pruebas, PRODUCCION para real
MP_DEFAULT_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXX...

# ---- APP ----
APP_URL=http://localhost:3000
# En producción Vercel: https://restaurante-saas.vercel.app

# ---- UCHAT (Opcional) ----
# Solo si quieres un webhook global (normalmente por restaurante en la BD)
# UCHAT_GLOBAL_WEBHOOK=https://www.uchat.com.au/api/incoming/...
